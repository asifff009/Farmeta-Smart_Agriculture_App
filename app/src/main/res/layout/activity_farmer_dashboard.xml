<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="0dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/header_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:elevation="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Farmers Dashboard"
                android:textColor="#FFFFFF"
                android:layout_marginRight="10dp"
                android:textSize="18sp"
                android:textStyle="bold"
                android:shadowColor="#000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:paddingLeft="10dp"
                android:shadowRadius="2"/>

            <Button
                android:id="@+id/btnUploadCrop"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upload Crops"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/_81c784"
                android:elevation="4dp"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="8dp"/>

        </LinearLayout>

        <!-- Fertilizer & History Buttons in Grid Card Layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:weightSum="2"
            android:padding="4dp">

            <!-- Fertilizer Calculator Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                android:backgroundTint="#43A047">

                <Button
                    android:id="@+id/btnFertilizer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fertilizer Calculator"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:backgroundTint="@android:color/transparent"
                    android:padding="16dp"
                    android:stateListAnimator="@null"/>
            </androidx.cardview.widget.CardView>

            <!-- Fertilizer History Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                android:backgroundTint="#2E7D32">

                <Button
                    android:id="@+id/btnFertilizerHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fertilizer History"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:backgroundTint="@android:color/transparent"
                    android:padding="16dp"
                    android:stateListAnimator="@null"/>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Spinner for Districts -->
        <Spinner
            android:id="@+id/spinnerDistrict"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:padding="0dp"
            android:background="@drawable/spinner_bg"
            android:spinnerMode="dropdown"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:background="@drawable/weather_box_bg"
            android:elevation="4dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:clipToOutline="true">

            <!-- Left: 2x2 Weather Icons -->
            <GridLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:rowCount="2"
                android:columnCount="2"
                android:layout_marginEnd="16dp"
                android:alignmentMode="alignMargins"
                android:useDefaultMargins="true">

                <!-- Sunny -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/sunny"
                        android:contentDescription="Sunny"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sunny"
                        android:textSize="12sp"
                        android:textColor="#0D47A1"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Rainy -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/raily"
                        android:contentDescription="Rainy"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rainy"
                        android:textSize="12sp"
                        android:textColor="#0D47A1"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Thunder -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/thunder"
                        android:contentDescription="Thunder"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thunder"
                        android:textSize="12sp"
                        android:textColor="#0D47A1"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Moderate -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/moderate"
                        android:contentDescription="Moderate"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Moderate"
                        android:textSize="12sp"
                        android:textColor="#0D47A1"
                        android:gravity="center"/>
                </LinearLayout>

            </GridLayout>

            <!-- Right: Existing Weather Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/tvCity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="City"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#0D47A1"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Temp"
                    android:textSize="14sp"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/tvHumidity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Humidity"
                    android:textSize="14sp"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/tvWind"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Wind"
                    android:textSize="14sp"
                    android:textColor="#1565C0"
                    android:layout_marginBottom="2dp"/>

                <TextView
                    android:id="@+id/tvDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textSize="14sp"
                    android:textColor="#0D47A1"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Image Slider -->
        <HorizontalScrollView
            android:id="@+id/imageSlider"
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:scrollbars="none"
            android:padding="10dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="290dp"
                    android:layout_height="130dp"
                    android:layout_marginRight="6dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/image_bg"
                    android:clipToOutline="true"
                    android:src="@drawable/i5"/>

                <ImageView
                    android:layout_width="290dp"
                    android:layout_height="130dp"
                    android:layout_marginRight="12dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/image_bg"
                    android:clipToOutline="true"
                    android:src="@drawable/i4"/>

                <ImageView
                    android:layout_width="290dp"
                    android:layout_height="130dp"
                    android:layout_marginRight="12dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/image_bg"
                    android:clipToOutline="true"
                    android:src="@drawable/i3"/>

                <ImageView
                    android:layout_width="290dp"
                    android:layout_height="130dp"
                    android:layout_marginRight="12dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/image_bg"
                    android:clipToOutline="true"
                    android:src="@drawable/i2"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Search Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="10dp"
            android:gravity="center_vertical">

            <TextView
                android:text="SCHECK OTHERS "
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#0D47A1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <View
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="1"
                android:layout_marginLeft="8dp"
                android:background="#0D47A1"/>
        </LinearLayout>

        <!-- Curved Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/grid_container_bg"
            android:padding="12dp">

            <!-- Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:rowCount="2"
                android:columnCount="4"
                android:alignmentMode="alignMargins"
                android:useDefaultMargins="true">

                <!-- GRID ITEM -->
                <LinearLayout
                    android:id="@+id/pesticide"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/pesticide"
                        android:background="@drawable/grid_image_bg"
                        android:clipToOutline="true"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pesticide"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_marginTop="6dp"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Fertilizer -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/ferti"
                        android:background="@drawable/grid_image_bg"
                        android:clipToOutline="true"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fertilizer"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_marginTop="6dp"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Fodder -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/fodd"
                        android:scaleType="centerCrop"
                        android:background="@drawable/grid_image_bg"
                        android:clipToOutline="true"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fodder"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_marginTop="6dp"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Onion -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/onion"
                        android:background="@drawable/grid_image_bg"
                        android:clipToOutline="true"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Onion"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_marginTop="6dp"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Pepper -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/pepp"
                        android:background="@drawable/grid_image_bg"
                        android:clipToOutline="true"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pepper"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_marginTop="6dp"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Garlic -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/garli"
                        android:background="@drawable/grid_image_bg"
                        android:clipToOutline="true"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Garlic"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_marginTop="6dp"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Lettuce -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/lettu"
                        android:background="@drawable/grid_image_bg"
                        android:clipToOutline="true"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lettuce"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_marginTop="6dp"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Broccoli -->
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/brocc"
                        android:background="@drawable/grid_image_bg"
                        android:clipToOutline="true"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Broccoli"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#000000"
                        android:layout_marginTop="6dp"
                        android:gravity="center"/>
                </LinearLayout>

            </GridLayout>


        </LinearLayout>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF7043"
            android:elevation="4dp"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="      "
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="      "
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="      "
            />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="      "
            />

    </LinearLayout>


</ScrollView>