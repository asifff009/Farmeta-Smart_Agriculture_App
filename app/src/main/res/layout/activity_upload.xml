<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f5f5f5"
    android:padding="20dp"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Crop Image Container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/dashed_border"
            android:layout_marginBottom="16dp"
            android:clipToOutline="true"
            android:elevation="4dp"
            android:padding="8dp">

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Selected Crop Image"
                android:background="@drawable/image_placeholder_bg"
                android:clipToOutline="true"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crop Preview"
                android:textColor="#666666"
                android:textSize="18sp"
                android:textStyle="italic"
                android:layout_gravity="center"/>
        </FrameLayout>

        <!-- Camera and Gallery Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:weightSum="2">

            <TextView
                android:id="@+id/btnCamera"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Open Camera"
                android:textColor="#333333"
                android:textStyle="bold"
                android:background="@drawable/edit_text_style"
                android:layout_marginEnd="8dp"
                android:padding="10dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnGallery"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Select from Gallery"
                android:textColor="#333333"
                android:textStyle="bold"
                android:background="@drawable/edit_text_style"
                android:layout_marginStart="8dp"
                android:padding="10dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <!-- Fill Others Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fill Others"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginBottom="16dp"/>

        <!-- First + Last Name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/firstName"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:hint="Your First Name"
                android:textSize="16sp"
                android:textColor="#1B1313"
                android:textColorHint="#999999"
                android:background="@drawable/edittext_rounded_bg"
                android:padding="12dp"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/lastName"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:hint="Your Last Name"
                android:textSize="16sp"
                android:textColor="#1B1313"
                android:textColorHint="#999999"
                android:background="@drawable/edittext_rounded_bg"
                android:padding="12dp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Crop Name -->
        <EditText
            android:id="@+id/editCropName"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Crop Name"
            android:textSize="16sp"
            android:textColor="#1B1313"
            android:textColorHint="#999999"
            android:background="@drawable/edittext_rounded_bg"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Crop Type Spinner -->
        <Spinner
            android:id="@+id/spinnerType"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/edittext_rounded_bg"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Quantity + Price -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/editQuantity"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:hint="Quantity"
                android:textSize="16sp"
                android:textColor="#1B1313"
                android:textColorHint="#999999"
                android:background="@drawable/edittext_rounded_bg"
                android:padding="12dp"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/editPrice"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:hint="Price"
                android:textSize="16sp"
                android:textColor="#1B1313"
                android:textColorHint="#999999"
                android:background="@drawable/edittext_rounded_bg"
                android:padding="12dp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Contact Number -->
        <EditText
            android:id="@+id/editContact"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Contact Number"
            android:textSize="16sp"
            android:textColor="#1B1313"
            android:textColorHint="#999999"
            android:background="@drawable/edittext_rounded_bg"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- Address -->
        <EditText
            android:id="@+id/editAddress"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Address"
            android:textSize="16sp"
            android:textColor="#1B1313"
            android:textColorHint="#999999"
            android:background="@drawable/edittext_rounded_bg"
            android:padding="12dp"
            android:layout_marginBottom="40dp"/> <!-- extra space above upload button -->

        <!-- Upload Button -->
        <Button
            android:id="@+id/btnUpload"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Upload Crop"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:backgroundTint="#FF5722"
            android:elevation="4dp"
            android:layout_marginBottom="40dp"/>

    </LinearLayout>
</ScrollView>